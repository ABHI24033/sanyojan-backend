	"item": [
		{
			"name": "Registration Flow",
			"item": [
				{
					"name": "1. Send OTP",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.otp) {",
									"        pm.collectionVariables.set(\"otp\", jsonData.otp);",
									"        console.log(\"OTP saved: \" + jsonData.otp);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"firstname\": \"Vipul\",\n    \"lastname\": \"Chandan\",\n    \"country_code\": \"+91\",\n    \"phone\": \"9876543210\",\n    \"password\": \"Password123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/auth/send-otp",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"auth",
								"send-otp"
							]
						},
						"description": "Send OTP for registration. Creates a new user or updates existing unverified user. Password is required and will be validated (min 8 characters, at least one letter and one number) and encrypted using bcrypt before storage."
					},
					"response": []
				},
				{
					"name": "2. Verify OTP",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.accessToken) {",
									"        pm.collectionVariables.set(\"accessToken\", jsonData.accessToken);",
									"        console.log(\"Access Token saved\");",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"phone\": \"9876543210\",\n    \"otp\": \"{{otp}}\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/auth/verify-otp",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"auth",
								"verify-otp"
							]
						},
						"description": "Verify OTP and complete registration. Sets is_verified=true and generates JWT tokens. Password is already set during Send OTP step, so no separate password setup is needed."
					},
					"response": []
				},
				{
					"name": "3. Resend OTP",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.otp) {",
									"        pm.collectionVariables.set(\"otp\", jsonData.otp);",
									"        console.log(\"New OTP saved: \" + jsonData.otp);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"phone\": \"9876543210\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/auth/resend-otp",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"auth",
								"resend-otp"
							]
						},
						"description": "Resend OTP for unverified users."
					},
					"response": []
				},
				{
					"name": "4. Set Password",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"phone\": \"9876543210\",\n    \"password\": \"Password123\",\n    \"confirm_password\": \"Password123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/auth/set-password",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"auth",
								"set-password"
							]
						},
						"description": "Set password for existing users who don't have a password set. For new registrations, password is set during Send OTP step. Password must be at least 8 characters with at least one letter and one number."
					},
					"response": []
				}
			],
			"description": "Complete registration flow: Send OTP (with password) → Verify OTP. Password is validated, encrypted, and stored during Send OTP step. Set Password endpoint is only needed for existing users without passwords."
		},
